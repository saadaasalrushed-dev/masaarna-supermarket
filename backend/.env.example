# Server
PORT=3000
NODE_ENV=development
DB_PATH=./masaarna.db
UPLOAD_DIR=./uploads
JWT_SECRET=change-this-to-a-long-random-string

# Store
MIN_ORDER_AED=1

# Public URL used in nGenius redirect (no trailing slash). Must match how users reach your site.
PUBLIC_BASE_URL=http://localhost:3000

# Images: WebP output; gzip for responses is handled by Express compression middleware.
IMAGE_QUALITY=85
IMAGE_THUMB_WIDTH=480
MAX_FILE_SIZE_MB=10

# Network International — N-Genius Online (Hosted Payment Page)
# Docs: https://docs.ngenius-payments.com/docs/obtain-an-access-token
#       https://docs.ngenius-payments.com/reference/create-an-order-paypage
NGENIUS_API_KEY=
NGENIUS_OUTLET_ID=
NGENIUS_BASE_URL=https://api-gateway.sandbox.ngenius-payments.com
# Optional: PURCHASE | AUTH
# NGENIUS_ORDER_ACTION=PURCHASE
# NGENIUS_SKIP_CONFIRM=0
# NGENIUS_SKIP_PM=0
